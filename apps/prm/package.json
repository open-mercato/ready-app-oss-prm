{
  "name": "@open-mercato/app",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "."
  ],
  "resolutions": {
    "@mikro-orm/core": "6.6.4",
    "@mikro-orm/knex": "6.6.4",
    "@mikro-orm/postgresql": "6.6.4",
    "@mikro-orm/migrations": "6.6.4"
  },
  "type": "module",
  "scripts": {
    "dev": "mercato server dev",
    "build": "next build",
    "build:packages": "echo 'Standalone app — no separate packages to build'",
    "start": "mercato server start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "jest --config jest.config.cjs",
    "test:integration": "npx playwright test --config .ai/qa/tests/playwright.config.ts",
    "test:integration:ephemeral": "mercato test ephemeral",
    "test:integration:ephemeral:start": "mercato test ephemeral --start-only",
    "test:integration:report": "mercato test coverage",
    "generate": "mercato generate",
    "db:generate": "mercato db generate",
    "db:migrate": "mercato db migrate",
    "db:greenfield": "mercato db greenfield",
    "initialize": "mercato init",
    "reinstall": "mercato init --reinstall",
    "preinstall": "node -e \"const v = process.versions.node.split('.').map(Number); if (v[0] < 24) { console.error('Node >= 24 required'); process.exit(1); }\""
  },
  "dependencies": {
    "@mikro-orm/core": "^6.6.2",
    "@mikro-orm/migrations": "^6.6.2",
    "@mikro-orm/postgresql": "^6.6.2",
    "@open-mercato/cache": "^0.4.8",
    "@open-mercato/cli": "^0.4.8",
    "@open-mercato/core": "^0.4.8",
    "@open-mercato/events": "^0.4.8",
    "@open-mercato/queue": "^0.4.8",
    "@open-mercato/scheduler": "^0.4.8",
    "@open-mercato/search": "^0.4.8",
    "@open-mercato/shared": "^0.4.8",
    "@open-mercato/ui": "^0.4.8",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@react-email/components": "^1.0.1",
    "@tanstack/react-query": "^5.90.12",
    "@tanstack/react-table": "^8.20.5",
    "@uiw/react-markdown-preview": "^5.1.5",
    "@uiw/react-md-editor": "^4.0.11",
    "ai": "^6.0.0",
    "awilix": "^12.0.5",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "lucide-react": "^0.556.0",
    "next": "16.1.5",
    "pdf2pic": "^3.2.0",
    "pg": "8.20.0",
    "react": "19.2.1",
    "react-big-calendar": "^1.19.4",
    "react-dom": "19.2.1",
    "react-email": "^5.0.6",
    "remark-gfm": "^4.0.1",
    "resend": "^6.5.2",
    "semver": "^7.7.3",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.1.17",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.2.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.0.0",
    "eslint-config-next": "16.0.7",
    "jest": "^30.2.0",
    "tailwindcss": "^4.1.17",
    "ts-jest": "^29.4.6",
    "tsx": "^4.7.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3"
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.5.0",
    "bullmq": "^5.34.8",
    "ioredis": "^5.8.2"
  },
  "imports": {
    "#generated/entities.ids.generated": {
      "types": "./.mercato/generated/entities.ids.generated.ts",
      "default": "./.mercato/generated/entities.ids.generated.ts"
    },
    "#generated/entity-fields-registry": {
      "types": "./.mercato/generated/entity-fields-registry.ts",
      "default": "./.mercato/generated/entity-fields-registry.ts"
    },
    "#generated/entities/*": {
      "types": "./.mercato/generated/entities/*/index.ts",
      "default": "./.mercato/generated/entities/*/index.ts"
    }
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
