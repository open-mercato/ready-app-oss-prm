# PRM Example App — Environment Configuration
# Copy this file to .env and adjust values for your environment.

# PostgreSQL connection string (required)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/open-mercato

# Docker Compose PostgreSQL settings
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=open-mercato
POSTGRES_PORT=5432

# JWT secret for auth tokens (required — change in production)
JWT_SECRET=change-me-dev-secret

# Public URL used in emails and links
APP_URL=http://localhost:3000

# Demo mode — seeds example data on initialize
DEMO_MODE=true

# Node environment
NODE_ENV=development

# Auto-spawn queue workers with the app
AUTO_SPAWN_WORKERS=true

# Queue storage (file-based for dev, Redis for production)
QUEUE_BASE_DIR=./.mercato/queue

# Cache strategy (memory | sqlite | redis)
CACHE_STRATEGY=sqlite
CACHE_SQLITE_PATH=./data/cache.db

# Search (token-based by default, Meilisearch optional)
OM_SEARCH_ENABLED=true
OM_SEARCH_MIN_LEN=3
OM_SEARCH_ENABLE_PARTIAL=true

# Tenant data encryption
TENANT_DATA_ENCRYPTION=yes
TENANT_DATA_ENCRYPTION_FALLBACK_KEY=dev-tenant-encryption-fallback-key-32chars

# Database pool
DB_POOL_MIN=5
DB_POOL_MAX=20

# Secret key for cron trigger endpoints (x-api-key header)
CRON_SECRET=

# Optional: Email provider for workflow notifications
# RESEND_API_KEY=

# Optional: Meilisearch for full-text search
# MEILISEARCH_HOST=http://localhost:7700
# MEILISEARCH_API_KEY=
